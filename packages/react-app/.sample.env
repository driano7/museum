# Infura IPFS
REACT_APP_INFURA_PROJECT_ID=
REACT_APP_INFURA_PROJECT_SECRET=

# RPC keys
REACT_APP_INFURA_KEY=
REACT_APP_ALCHEMY_KEY=
# Monad testnet RPC for dApp reads/writes
REACT_APP_PROVIDER=https://testnet-rpc.monad.xyz


# Etherscan API key(s)
REACT_APP_ETHERSCAN_API_KEY=

# Web3Modal default hardhat provider
REACT_APP_HARDHAT_HOST=

# Blocknative Dapp ID
REACT_APP_BLOCKNATIVE_DAPP_ID=

# Codespaces
REACT_APP_CODESPACES=

# Privy (frontend)
REACT_APP_PRIVY_APP_ID=
# Do not put PRIVY app secret in frontend env files.

# Tickets contract (frontend)
REACT_APP_TICKETS_CONTRACT_ADDRESS=
# Optional override when contract ABI does not expose usdc()
REACT_APP_USDC_ADDRESS=

# Stripe demo checkout (test mode only)
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Comma-separated Stripe Price IDs (fallback / mexicano), e.g. price_abc123,price_def456
REACT_APP_STRIPE_PRICE_IDS=
# Mexicano (preferred explicit variable)
REACT_APP_STRIPE_PRICE_IDS_MX=
# Internacional (required when CURP is absent/invalid)
REACT_APP_STRIPE_PRICE_IDS_INTL=
# For non-Stripe calculations (e.g. crypto/manual demo), defaults to 1.4
REACT_APP_INTERNATIONAL_PRICE_MULTIPLIER=1.4

# Crypto payment demo
# Receiver wallet for ETH payments
REACT_APP_CRYPTO_RECEIVER=
# Optional network label shown in UI
REACT_APP_CRYPTO_CHAIN_LABEL=Ethereum
